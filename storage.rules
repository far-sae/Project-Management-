rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Project files: allow authenticated users in the same org to read/write
    match /projects/{projectId}/files/{fileName} {
      allow read, write: if request.auth != null;
    }
    // Task attachments
    match /projects/{projectId}/tasks/{taskId}/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
