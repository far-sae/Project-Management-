# Supabase Configuration (Required)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Task lock PIN: optional server RPC (migration 021). Leave unset or omit — the app uses a
# client-side PIN check and will not call PostgREST. After you apply
# supabase/migrations/021_verify_task_lock_pin.sql and NOTIFY pgrst, 'reload schema'; set:
# VITE_VERIFY_TASK_LOCK_PIN_RPC=true

# App Owner User IDs (comma-separated user IDs that have full access)
# Get from: https://app.supabase.com/project/_/settings/api
VITE_APP_OWNER_USER_IDS=

# EmailJS (Optional - for sending emails)
# Service + Public Key are shared across all templates.
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Template used for project invitation emails.
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id

# Template used for in-app notification emails — task assignments, due-soon, overdue,
# comments. If unset, falls back to VITE_EMAILJS_TEMPLATE_ID. To get task assignment + due
# date alerts via email, set this template up in the EmailJS dashboard with these vars:
# {{to_email}} {{to_name}} {{subject}} {{title}} {{message}} {{action_url}} {{actor_name}}
# {{project_name}} {{task_title}}
# Without SERVICE_ID + PUBLIC_KEY + NOTIFICATION_TEMPLATE_ID (or fallback invitation template),
# emails are skipped (browser console: "EmailJS notification template not configured").
# Recipients need email on Supabase user_profiles (lookup by user id).
VITE_EMAILJS_NOTIFICATION_TEMPLATE_ID=your_emailjs_notification_template_id

